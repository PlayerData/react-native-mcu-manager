{
  "name": "@playerdata/react-native-mcu-manager",
  "title": "React Native MCU Manager",
  "version": "0.0.1-development",
  "description": "React Native Wrappers for MCUMgr's Android / iOS client libraries",
  "source": "src/",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "open:ios": "open -a \"Xcode\" example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "lint": "eslint --report-unused-disable-directives --max-warnings=139 src",
    "typecheck": "pnpm tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "mcumgr"
  ],
  "author": "PlayerData <dev@playerdata.com> (https://github.com/PlayerData)",
  "license": "MIT",
  "repository": "https://github.com/PlayerData/react-native-mcu-manager",
  "bugs": {
    "url": "https://github.com/PlayerData/react-native-mcu-manager/issues"
  },
  "homepage": "https://github.com/PlayerData/react-native-mcu-manager#readme",
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "pnpm run lint && pnpm typescript"
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native-community",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "dependencies": {
    "expo": "~51.0.8",
    "react": "18.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "expo-modules-core": "~1.12.20",
    "@babel/core": "^7.24.5",
    "@commitlint/config-conventional": "^19.2.2",
    "@react-native-community/eslint-config": "^3.2.0",
    "@types/react": "^18.2.79",
    "@types/uuid": "9.0.8",
    "commitlint": "19.3.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "prettier": "^3.2.5",
    "semantic-release": "^23.1.1"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "resolutions": {
    "es-abstract": ">1.18.0",
    "ts-invariant": "0.10.3",
    "tslib": ">2.0",
    "pretty-format": "^29.0.0"
  }
}
